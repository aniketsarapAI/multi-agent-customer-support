# ── OpenRouter / LLM ──
OPENROUTER_API_KEY=your-openrouter-api-key-here
OPENAI_BASE_URL=https://openrouter.ai/api/v1
LLM_MODEL=openai/gpt-4o-mini
FALLBACK_MODEL=openai/gpt-4o-mini
LLM_TEMPERATURE=0
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ── TiDB / MySQL ──
MYSQL_HOST=gateway01.eu-central-1.prod.aws.tidbcloud.com
MYSQL_PORT=4000
MYSQL_USER=your-tidb-user.root
MYSQL_PASSWORD=your-tidb-password
MYSQL_DATABASE=ecommerce_v2

# ── LangSmith Tracing (optional) ──
LANGCHAIN_TRACING_V2=true
LANGCHAIN_ENDPOINT=https://api.smith.langchain.com
LANGCHAIN_API_KEY=lsv2_...
LANGCHAIN_PROJECT=selfrag

# ── Gmail SMTP Escalation (optional) ──
# Generate an app password at https://myaccount.google.com/apppasswords
GMAIL_USER=your.email@gmail.com
GMAIL_APP_PASSWORD=abcd1234efgh5678
SUPPORT_EMAIL=support@company.com

# ── Application ──
APP_ENV=development
LOG_LEVEL=INFO
