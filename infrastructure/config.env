# ── AWS Configuration ──────────────────────────────────────
AWS_REGION=us-east-1
AWS_ACCOUNT_ID=123456789012        # CHANGE THIS

# ── ECR ────────────────────────────────────────────────────
ECR_REPO_NAME=selfragmcp

# ── ECS ────────────────────────────────────────────────────
CLUSTER_NAME=selfragmcp-cluster

# ── Networking ─────────────────────────────────────────────
VPC_CIDR=10.0.0.0/16
PUBLIC_SUBNET_1_CIDR=10.0.1.0/24
PUBLIC_SUBNET_2_CIDR=10.0.2.0/24
PRIVATE_SUBNET_1_CIDR=10.0.3.0/24
PRIVATE_SUBNET_2_CIDR=10.0.4.0/24

# ── Domain (optional — set these for custom domain) ───────
DOMAIN_NAME=support.example.com   # CHANGE THIS or leave blank for ALB DNS
ACM_CERTIFICATE_ARN=              # Leave blank if DOMAIN_NAME is blank

# ── Secrets Manager ───────────────────────────────────────
SECRETS_NAME=selfragmcp/prod/api-keys
