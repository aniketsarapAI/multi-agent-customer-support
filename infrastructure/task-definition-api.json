{
    "family": "selfragmcp-api",
    "networkMode": "awsvpc",
    "requiresCompatibilities": ["FARGATE"],
    "cpu": "2048",
    "memory": "4096",
    "executionRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/ecsTaskExecutionRole",
    "taskRoleArn": "arn:aws:iam::${AWS_ACCOUNT_ID}:role/ecsTaskExecutionRole",
    "containerDefinitions": [
        {
            "name": "api",
            "image": "${AWS_ACCOUNT_ID}.dkr.ecr.${AWS_REGION}.amazonaws.com/${ECR_REPO_NAME}:api-latest",
            "essential": true,
            "portMappings": [
                {
                    "containerPort": 8000,
                    "protocol": "tcp"
                }
            ],
            "healthCheck": {
                "command": ["CMD-SHELL", "python3 -c \"import urllib.request; urllib.request.urlopen('http://localhost:8000/health')\""],
                "interval": 15,
                "timeout": 5,
                "startPeriod": 90,
                "retries": 3
            },
            "logConfiguration": {
                "logDriver": "awslogs",
                "options": {
                    "awslogs-group": "/ecs/selfragmcp/api",
                    "awslogs-region": "${AWS_REGION}",
                    "awslogs-stream-prefix": "api"
                }
            },
            "secrets": [
                { "name": "OPENROUTER_API_KEY", "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRETS_NAME}-XXXXX:OPENROUTER_API_KEY::" },
                { "name": "MYSQL_HOST",         "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRETS_NAME}-XXXXX:MYSQL_HOST::" },
                { "name": "MYSQL_PORT",         "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRETS_NAME}-XXXXX:MYSQL_PORT::" },
                { "name": "MYSQL_USER",         "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRETS_NAME}-XXXXX:MYSQL_USER::" },
                { "name": "MYSQL_PASSWORD",     "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRETS_NAME}-XXXXX:MYSQL_PASSWORD::" },
                { "name": "GMAIL_USER",         "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRETS_NAME}-XXXXX:GMAIL_USER::" },
                { "name": "GMAIL_APP_PASSWORD", "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRETS_NAME}-XXXXX:GMAIL_APP_PASSWORD::" },
                { "name": "SUPPORT_EMAIL",      "valueFrom": "arn:aws:secretsmanager:${AWS_REGION}:${AWS_ACCOUNT_ID}:secret:${SECRETS_NAME}-XXXXX:SUPPORT_EMAIL::" }
            ]
        }
    ]
}
